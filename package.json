{
	"name": "obsidian-tag-cleaner",
	"version": "1.0.0",
	"description": "Obsidian plugin to remove unclosed (trailing-slash) hashtags from notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "node --experimental-vm-modules node_modules/.bin/jest"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/jest": "^29.5.14",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jest": "^29.7.0",
		"jiti": "2.6.1",
		"ts-jest": "^29.4.9",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"jest-util": "^29.7.0",
		"obsidian": "latest"
	}
}
